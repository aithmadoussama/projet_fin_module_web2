<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/edit_profile_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_violet"
    tools:context=".ui.EditProfileClientActivity">

    <!-- Toolbar -->
    <include
        android:id="@+id/topAppBar"
        layout="@layout/toolbar_top"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Avatar centré -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingTop="8dp"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/bg_avatar_violet"
                    android:padding="16dp"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <!-- Carte formulaire -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#F5F0FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#DDD6FE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section : Informations -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INFORMATIONS PERSONNELLES"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#5B21B6"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp" />

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutEmail"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        android:layout_marginBottom="14dp"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Téléphone -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutPhone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Téléphone"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="#EDE9FE"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp" />

                    <!-- Section : Mot de passe -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHANGER LE MOT DE PASSE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#5B21B6"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp" />

                    <!-- Ancien mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutOldPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mot de passe actuel"
                        android:layout_marginBottom="14dp"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#A78BFA"
                        app:startIconDrawable="@drawable/ic_clock"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editOldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Nouveau mot de passe -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutNewPassword"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nouveau mot de passe"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#A78BFA"
                        app:startIconDrawable="@drawable/ic_clock"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bouton enregistrer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Enregistrer les modifications"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="#7C3AED"
                app:cornerRadius="14dp"
                app:rippleColor="#6D28D9"
                app:icon="@drawable/ic_edit"
                app:iconTint="#FFFFFF"
                app:iconGravity="textStart" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

