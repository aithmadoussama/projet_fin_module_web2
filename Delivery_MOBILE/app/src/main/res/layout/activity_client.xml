<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/client_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_violet"
    tools:context=".ui.ClientActivity">

    <!-- Toolbar -->
    <include
        android:id="@+id/topAppBar"
        layout="@layout/toolbar_top"
        android:layout_width="0dp"
        android:layout_height="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenu scrollable d'accueil -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Salutation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bonjour 👋"
                        android:textSize="13sp"
                        android:textColor="#7C3AED" />

                    <TextView
                        android:id="@+id/txtWelcomeName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#3B0764"
                        android:fontFamily="serif" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/imgAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_person"
                    android:background="@drawable/bg_avatar_violet"
                    android:padding="10dp"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <!-- Carte dernière livraison -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLastDelivery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#7C3AED"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DERNIÈRE LIVRAISON"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="#DDD6FE"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/txtLastId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#CMD-—"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/txtLastAdresse"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Départ → Destination"
                        android:textSize="12sp"
                        android:textColor="#EDE9FE"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/txtLastStatut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Statut"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#5B21B6"
                        android:background="@drawable/bg_white_pill"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Titre Actions rapides -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIONS RAPIDES"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#3B0764"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Grille ligne 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDelivery"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="#F5F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0.5dp"
                    app:strokeColor="#DDD6FE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_route" android:background="@drawable/bg_badge_statut"
                            android:padding="9dp" android:scaleType="fitCenter" app:tint="#7C3AED"
                            android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Nouvelle" android:textSize="13sp" android:textStyle="bold" android:textColor="#3B0764" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Livraison" android:textSize="11sp" android:textColor="#7C3AED" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="#F5F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0.5dp"
                    app:strokeColor="#DDD6FE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_clock" android:background="@drawable/bg_badge_statut"
                            android:padding="9dp" android:scaleType="fitCenter" app:tint="#7C3AED"
                            android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Historique" android:textSize="13sp" android:textStyle="bold" android:textColor="#3B0764" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Commandes" android:textSize="11sp" android:textColor="#7C3AED" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Grille ligne 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardBackgroundColor="#F5F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0.5dp"
                    app:strokeColor="#DDD6FE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_person" android:background="@drawable/bg_badge_statut"
                            android:padding="9dp" android:scaleType="fitCenter" app:tint="#7C3AED"
                            android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mon Profil" android:textSize="13sp" android:textStyle="bold" android:textColor="#3B0764" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Informations" android:textSize="11sp" android:textColor="#7C3AED" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardSupport"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    app:cardBackgroundColor="#F5F0FF"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0.5dp"
                    app:strokeColor="#DDD6FE">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="16dp">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_support" android:background="@drawable/bg_badge_statut"
                            android:padding="9dp" android:scaleType="fitCenter" app:tint="#7C3AED"
                            android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Support" android:textSize="13sp" android:textStyle="bold" android:textColor="#3B0764" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Aide" android:textSize="11sp" android:textColor="#7C3AED" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Statistiques -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F5F0FF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#DDD6FE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/txtStatTotal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#7C3AED" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total" android:textSize="10sp" android:textColor="#888" />
                    </LinearLayout>

                    <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#EDE9FE"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/txtStatLivre" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#3B6D11" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Livrées" android:textSize="10sp" android:textColor="#888" />
                    </LinearLayout>

                    <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#EDE9FE"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/txtStatEnCours" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#5B21B6" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="En cours" android:textSize="10sp" android:textColor="#888" />
                    </LinearLayout>

                    <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#EDE9FE"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/txtStatAnnule" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="#A32D2D" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Annulées" android:textSize="10sp" android:textColor="#888" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
