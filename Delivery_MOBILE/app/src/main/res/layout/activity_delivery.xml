<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_violet"
    tools:context=".ui.NewDeliveryActivity">

    <!-- Toolbar -->
    <include
        android:id="@+id/topAppBar"
        layout="@layout/toolbar_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:title=""
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />



    <!-- Contenu scrollable -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topAppBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Carte formulaire -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#F5F0FF"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0.5dp"
                app:strokeColor="#DDD6FE">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Label section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DÉTAILS DE LA LIVRAISON"
                        android:textColor="#5B21B6"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="16dp" />

                    <!-- Champ départ -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDepart"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Adresse de départ"
                        app:startIconDrawable="@drawable/ic_location_start"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_depart"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Flèche départ → arrivée -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_arrow_down"
                            android:background="@drawable/bg_badge_statut"
                            android:padding="6dp"
                            app:tint="#7C3AED" />
                    </LinearLayout>

                    <!-- Champ arrivée -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutArrivee"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Adresse d'arrivée"
                        app:startIconDrawable="@drawable/ic_location_end"
                        app:startIconTint="#7C3AED"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_arrivee"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Champ date -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layoutDate"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Date (AAAA-MM-JJ)"
                        app:startIconDrawable="@drawable/ic_calendar"
                        app:startIconTint="#A78BFA"
                        app:hintTextColor="#7C3AED"
                        app:boxStrokeColor="@color/violet_stroke_selector"
                        app:boxStrokeWidth="1.5dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:textColor="#3B0764"
                            android:textSize="14sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bouton confirmer -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_valider"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:text="Confirmer la livraison"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#7C3AED"
                app:cornerRadius="14dp"
                app:rippleColor="#6D28D9" />

            <!-- Texte informatif -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:text="Votre livraison sera confirmée sous peu"
                android:textColor="#8B5CF6"
                android:textSize="11sp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
